version: '3.8'

services:
  db:
    image: postgres:15-alpine
    container_name: but_tc_db
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./backup_full_descriptions.sql:/docker-entrypoint-initdb.d/init.sql
    ports:
      - "5432:5432"
    networks:
      - app_network

  nextcloud:
    image: nextcloud:stable-apache
    container_name: but_tc_nextcloud
    restart: unless-stopped
    depends_on:
      - redis
      - db_nextcloud
    ports:
      - "8082:80"
    extra_hosts:
      - "${DOMAIN}:host-gateway"
      - "nextcloud.${DOMAIN}:host-gateway"
      - "only-office.${DOMAIN}:host-gateway"
      - "home.${DOMAIN}:host-gateway"
    environment:
      - NEXTCLOUD_ADMIN_USER=${NEXTCLOUD_ADMIN_USER}
      - NEXTCLOUD_ADMIN_PASSWORD=${NEXTCLOUD_ADMIN_PASSWORD}
      - NEXTCLOUD_TRUSTED_DOMAINS=localhost 127.0.0.1 nextcloud projet-edu.eu ${DOMAIN} *.${DOMAIN}
      - OVERWRITEPROTOCOL=https
      - REDIS_HOST=redis
      - POSTGRES_HOST=db_nextcloud
      - POSTGRES_DB=nextcloud
      - POSTGRES_USER=nextcloud
      - POSTGRES_PASSWORD=nextcloud_password
    volumes:
      - nextcloud_data:/var/www/html
    networks:
      - app_network

  onlyoffice:
    image: onlyoffice/documentserver:latest
    container_name: but_tc_onlyoffice
    restart: unless-stopped
    ports:
      - "8083:80"
    extra_hosts:
      - "${DOMAIN}:host-gateway"
      - "nextcloud.${DOMAIN}:host-gateway"
      - "only-office.${DOMAIN}:host-gateway"
      - "home.${DOMAIN}:host-gateway"
    environment:
      - JWT_ENABLED=true
      - JWT_SECRET=onlyoffice_secret
      - JWT_HEADER=Authorization
      - USE_UNAUTHORIZED_STORAGE=true
      - ALLOW_PRIVATE_IP_ADDRESS=true
      - NODE_TLS_REJECT_UNAUTHORIZED=0
    networks:
      - app_network

  redis:
    image: redis:alpine
    container_name: but_tc_redis
    restart: unless-stopped
    networks:
      - app_network

  db_nextcloud:
    image: postgres:15-alpine
    container_name: but_tc_db_nextcloud
    restart: unless-stopped
    environment:
      POSTGRES_USER: nextcloud
      POSTGRES_PASSWORD: nextcloud_password
      POSTGRES_DB: nextcloud
    volumes:
      - nextcloud_db_data:/var/lib/postgresql/data
    networks:
      - app_network

  db_mattermost:
    image: postgres:15-alpine
    container_name: but_tc_db_mattermost
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${MM_DB_USER}
      POSTGRES_PASSWORD: ${MM_DB_PASSWORD}
      POSTGRES_DB: mattermost
    volumes:
      - mattermost_db_data:/var/lib/postgresql/data
    networks:
      - app_network

  db_mattermost_test:
    image: postgres:15-alpine
    container_name: but_tc_db_mm_test
    restart: unless-stopped
    environment:
      POSTGRES_USER: mmuser_test
      POSTGRES_PASSWORD: mmpassword_test
      POSTGRES_DB: mattermost_test
    volumes:
      - mattermost_test_db_data:/var/lib/postgresql/data
    networks:
      - app_network

  db_keycloak:
    image: postgres:15-alpine
    container_name: but_tc_db_keycloak
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${KC_DB_USER}
      POSTGRES_PASSWORD: ${KC_DB_PASSWORD}
      POSTGRES_DB: keycloak
    volumes:
      - keycloak_db_data:/var/lib/postgresql/data
    networks:
      - app_network

  db_odoo:
    image: postgres:15-alpine
    container_name: but_tc_db_odoo
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${ODOO_DB_USER}
      POSTGRES_PASSWORD: ${ODOO_DB_PASSWORD}
      POSTGRES_DB: postgres
    volumes:
      - odoo_db_data:/var/lib/postgresql/data
    networks:
      - app_network

  odoo:
    build:
      context: ./apps/odoo
    container_name: but_tc_odoo
    restart: unless-stopped
    depends_on:
      - db_odoo
    environment:
      - HOST=db_odoo
      - USER=${ODOO_DB_USER}
      - PASSWORD=${ODOO_DB_PASSWORD}
      - ODOO_MASTER_PASSWORD=${ODOO_MASTER_PASSWORD}
    volumes:
      - odoo_data:/var/lib/odoo
    networks:
      - app_network

  keycloak:
    image: quay.io/keycloak/keycloak:latest
    container_name: but_tc_keycloak
    restart: unless-stopped
    command: start-dev --hostname-strict=false --import-realm
    environment:
      - KC_DB=postgres
      - KC_DB_URL=jdbc:postgresql://db_keycloak:5432/keycloak
      - KC_DB_USERNAME=${KC_DB_USER}
      - KC_DB_PASSWORD=${KC_DB_PASSWORD}
      - KEYCLOAK_ADMIN=${KEYCLOAK_ADMIN}
      - KEYCLOAK_ADMIN_PASSWORD=${KEYCLOAK_ADMIN_PASSWORD}
      - KC_HOSTNAME=keycloak.${DOMAIN}
      - KC_PROXY_HEADERS=xforwarded
      - KC_HTTP_ENABLED=true
    volumes:
      - ./infrastructure/keycloak/import:/opt/keycloak/data/import
    depends_on:
      - db_keycloak
    ports:
      - "8080:8080"
    networks:
      - app_network

  mattermost:
    image: mattermost/mattermost-team-edition:latest
    container_name: but_tc_mattermost
    restart: unless-stopped
    depends_on:
      - db_mattermost
    environment:
      - MM_SQLSETTINGS_DRIVERNAME=postgres
      - MM_SQLSETTINGS_DATASOURCE=postgres://${MM_DB_USER}:${MM_DB_PASSWORD}@db_mattermost:5432/mattermost?sslmode=disable&connect_timeout=10
      - MM_SERVICESETTINGS_SITEURL=https://mattermost.${DOMAIN}
      - MM_SERVICESETTINGS_SCHEMEOVERRIDE=https
      - MM_SERVICESETTINGS_TRUSTEDPROXYIPHEADER=X-Forwarded-For
      - MM_SERVICESETTINGS_ENABLETRUSTEDPROXIES=true
      - MM_SERVICESETTINGS_TRUSTEDPROXIES=0.0.0.0/0,::/0
      - MM_SERVICESETTINGS_ALLOWEDUNTRUSTEDINTERNALCONNECTIONS=localhost 127.0.0.1 ${DOMAIN}
      - MM_SERVICESETTINGS_ENABLEDEVELOPER=true
      - MM_LOGSETTINGS_ENABLEDIAGNOSTICS=false
      - MM_LOGINSETTINGS_ENABLEOAUTHGAMES=false
      - MM_GITLABSETTINGS_ENABLE=true
      - MM_GITLABSETTINGS_ID=${MM_GITLABSETTINGS_ID}
      - MM_GITLABSETTINGS_SECRET=${MM_GITLABSETTINGS_SECRET}
      - MM_GITLABSETTINGS_DISCOVERYENDPOINT=https://keycloak.${DOMAIN}/realms/but-tc/.well-known/openid-configuration
      - MM_GITLABSETTINGS_AUTHENDPOINT=https://keycloak.${DOMAIN}/realms/but-tc/protocol/openid-connect/auth
      - MM_GITLABSETTINGS_TOKENENDPOINT=http://but_tc_keycloak:8080/realms/but-tc/protocol/openid-connect/token
      - MM_GITLABSETTINGS_USERAPIENDPOINT=http://but_tc_keycloak:8080/realms/but-tc/protocol/openid-connect/userinfo
      - MM_GITLABSETTINGS_BUTTONTEXT=Connexion avec Keycloak
    ports:
      - "8065:8065"
    volumes:
      - mattermost_data:/mattermost/data
      - mattermost_config:/mattermost/config
      - mattermost_logs:/mattermost/logs
      - mattermost_plugins:/mattermost/plugins
    networks:
      - app_network

  mattermost_test:
    image: mattermost/mattermost-team-edition:9.11.3
    container_name: but_tc_mm_test
    restart: unless-stopped
    depends_on:
      - db_mattermost_test
    environment:
      - MM_SQLSETTINGS_DRIVERNAME=postgres
      - MM_SQLSETTINGS_DATASOURCE=postgres://mmuser_test:mmpassword_test@db_mattermost_test:5432/mattermost_test?sslmode=disable&connect_timeout=10
      - MM_SERVICESETTINGS_SITEURL=https://mm-test.educ-ai.fr
      - MM_SERVICESETTINGS_TRUSTEDPROXYIPHEADER=X-Forwarded-For
      - MM_SERVICESETTINGS_ENABLETRUSTEDPROXIES=true
      - MM_SERVICESETTINGS_TRUSTEDPROXIES=0.0.0.0/0,::/0
      - MM_GITLABSETTINGS_ENABLE=true
      - MM_GITLABSETTINGS_ID=${MM_GITLABSETTINGS_ID}
      - MM_GITLABSETTINGS_SECRET=${MM_GITLABSETTINGS_SECRET}
      - MM_GITLABSETTINGS_AUTHENDPOINT=https://keycloak.${DOMAIN}/realms/but-tc/protocol/openid-connect/auth
      - MM_GITLABSETTINGS_TOKENENDPOINT=http://but_tc_keycloak:8080/realms/but-tc/protocol/openid-connect/token
      - MM_GITLABSETTINGS_USERAPIENDPOINT=http://but_tc_keycloak:8080/realms/but-tc/protocol/openid-connect/userinfo
      - MM_GITLABSETTINGS_BUTTONTEXT=Keycloak
    ports:
      - "8066:8065"
    volumes:
      - mattermost_test_data:/mattermost/data
      - mattermost_test_config:/mattermost/config
    networks:
      - app_network

  api:
    build:
      context: ./apps/api
    container_name: but_tc_api
    restart: unless-stopped
    depends_on:
      - db
    environment:
      - DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
      - LDAP_URL=${LDAP_URL}
      - LDAP_BASE_DN=${LDAP_BASE_DN}
      - LDAP_BIND_DN=${LDAP_BIND_DN}
      - LDAP_BIND_PASSWORD=${LDAP_BIND_PASSWORD}
      - NEXTCLOUD_URL=https://nextcloud.${DOMAIN}
      - NEXTCLOUD_ADMIN=${NEXTCLOUD_ADMIN_USER}
      - NEXTCLOUD_PASS=${NEXTCLOUD_ADMIN_PASSWORD}
      - ROOT_PATH=/api
      - KEYCLOAK_URL=http://but_tc_keycloak:8080
      - KEYCLOAK_REALM=but-tc
      - KEYCLOAK_CLIENT_ID=${KEYCLOAK_CLIENT_ID}
      - KEYCLOAK_CLIENT_SECRET=${KEYCLOAK_CLIENT_SECRET}
      - ODOO_DB_URL=postgresql://${ODOO_DB_USER}:${ODOO_DB_PASSWORD}@db_odoo:5432/postgres
      - ODOO_MASTER_PASSWORD=${ODOO_MASTER_PASSWORD}
      - DOMAIN=${DOMAIN}
      - SMTP_HOST=${SMTP_HOST}
      - SMTP_PORT=${SMTP_PORT}
      - SMTP_USER=${SMTP_USER}
      - SMTP_PASS=${SMTP_PASS}
      - SMTP_TLS=true
    volumes:
      - ./docs:/app/data_source/docs
      - ./fiches:/app/data_source/fiches
      - rag_vectors:/app/vectors
      - nextcloud_data:/nextcloud_data
    networks:
      - app_network

  web:
    build:
      context: ./apps/web
    container_name: but_tc_web
    restart: unless-stopped
    depends_on:
      - api
    networks:
      - app_network

  dashboard:
    build:
      context: ./apps/dashboard
    container_name: but_tc_dashboard
    restart: unless-stopped
    environment:
      - DOMAIN=${DOMAIN}
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./apps/dashboard/nginx.conf:/etc/nginx/conf.d/default.conf
      - ./infrastructure/local/ssl/dashboard.crt:/etc/nginx/ssl/dashboard.crt
      - ./infrastructure/local/ssl/dashboard.key:/etc/nginx/ssl/dashboard.key
    depends_on:
      - web
      - api
    networks:
      - app_network

  tunnel:
    image: cloudflare/cloudflared
    container_name: but_tc_tunnel
    restart: unless-stopped
    environment:
      - TUNNEL_TOKEN=${CLOUDFLARE_TOKEN}
    command: tunnel run
    networks:
      - app_network

volumes:
  postgres_data:
  nextcloud_data:
  nextcloud_db_data:
  keycloak_db_data:
  odoo_data:
  odoo_db_data:
  rag_vectors:
  mattermost_db_data:
  mattermost_data:
  mattermost_config:
  mattermost_logs:
  mattermost_plugins:
  mattermost_test_db_data:
  mattermost_test_data:
  mattermost_test_config:

networks:
  app_network:
    driver: bridge
